# Caddy and public URLs
CADDY_SITE_ADDRESS=http://localhost
PUBLIC_STORE_ORIGIN=http://localhost
PUBLIC_ADMIN_ORIGIN=http://localhost
PUBLIC_AUTH_ORIGIN=http://localhost

# Storefront runtime
# MEDUSA_BACKEND_URL: local dev (host machine)
# STOREFRONT_MEDUSA_BACKEND_URL: docker network target
MEDUSA_BACKEND_URL=http://localhost:9000
STOREFRONT_MEDUSA_BACKEND_URL=http://backend:9000
NEXT_PUBLIC_BASE_URL=http://localhost
NEXT_PUBLIC_DEFAULT_REGION=hu
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_webshop_medusa_local
NEXT_PUBLIC_ENABLE_MANUAL_PAYMENT=true
REVALIDATE_SECRET=replace-me-with-a-long-random-string

# Backend runtime
# DATABASE_URL / REDIS_URL / CACHE_REDIS_URL: local dev (host machine)
# DOCKER_*: docker compose backend container
DATABASE_URL=postgres://medusa:medusa@localhost:5432/medusa?sslmode=disable
DOCKER_DATABASE_URL=postgres://medusa:medusa@postgres:5432/medusa?sslmode=disable
POSTGRES_DB=medusa
POSTGRES_USER=medusa
POSTGRES_PASSWORD=medusa
REDIS_URL=redis://localhost:6379
CACHE_REDIS_URL=redis://localhost:6379
DOCKER_REDIS_URL=redis://redis:6379
DOCKER_CACHE_REDIS_URL=redis://redis:6379
STORE_CORS=http://localhost,http://localhost:8000
ADMIN_CORS=http://localhost,http://localhost:9000
AUTH_CORS=http://localhost,http://localhost:8000,http://localhost:9000
JWT_SECRET=replace-me-with-a-long-random-string
COOKIE_SECRET=replace-me-with-a-long-random-string
PUBLISHABLE_API_KEY=pk_webshop_medusa_local
BOOTSTRAP_DEFAULT_REGION=hu
BOOTSTRAP_DEFAULT_CURRENCY=huf
EVENTS_CONCURRENCY=1
RUN_BOOTSTRAP=true
RUN_SEED_TEST_PRODUCTS=true
ENABLE_MANUAL_PAYMENT=true

# Google auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost/api/auth/google/callback

# SimplePay placeholders
SIMPLEPAY_MERCHANT=
SIMPLEPAY_SECRET_KEY=
SIMPLEPAY_SANDBOX=true
SIMPLEPAY_SUCCESS_URL=http://localhost/checkout/success
SIMPLEPAY_FAILURE_URL=http://localhost/checkout/failure
SIMPLEPAY_CALLBACK_URL=http://localhost/store/simplepay/callback
SIMPLEPAY_SIGNATURE_HEADER=x-simplepay-signature
SIMPLEPAY_SIGNATURE_ALGORITHM=sha256
SIMPLEPAY_REQUIRE_SIGNATURE=true

# Initial admin credentials (used only for documentation/manual creation)
MEDUSA_ADMIN_EMAIL=admin@example.com
MEDUSA_ADMIN_PASSWORD=replace-me-with-a-strong-password
